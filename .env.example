# Локальная среда приложения
APP_ENV=
APP_NAME=
LOG_LEVEL=

# Сетевые настройки
HTTP_PORT=

# Proposal runner
PROPOSAL_REPOSITORY_URL=
PROPOSAL_BASE_BRANCH=
PROPOSAL_REMOTE_NAME=
PROPOSAL_BRANCH_PREFIX=
PROPOSAL_PR_TITLE_PREFIX=
PROPOSAL_CLEANUP_TEMP=
PROPOSAL_POLL_INTERVAL=
PROPOSAL_GIT_PATH=
PROPOSAL_CODEX_PATH=
PROPOSAL_GH_PATH=

# Linear TaskManager
LINEAR_API_URL=
LINEAR_API_TOKEN=
LINEAR_PROJECT_ID=
LINEAR_STATE_READY_TO_PROPOSE_ID=
LINEAR_STATE_READY_TO_CODE_ID=
LINEAR_STATE_READY_TO_ARCHIVE_ID=
LINEAR_STATE_PROPOSING_IN_PROGRESS_ID=
LINEAR_STATE_CODE_IN_PROGRESS_ID=
LINEAR_STATE_ARCHIVING_IN_PROGRESS_ID=
LINEAR_STATE_NEED_PROPOSAL_REVIEW_ID=
LINEAR_STATE_NEED_CODE_REVIEW_ID=
LINEAR_STATE_NEED_ARCHIVE_REVIEW_ID=

# Cross-Agent Review Stage. Заполните все три AI-review state ID одновременно
# чтобы включить стадию; оставьте пустыми чтобы выключить (producer-runner'ы
# тогда переводят задачу сразу в human review state). Частичная конфигурация —
# ошибка старта.
LINEAR_STATE_NEED_PROPOSAL_AI_REVIEW_ID=
LINEAR_STATE_NEED_CODE_AI_REVIEW_ID=
LINEAR_STATE_NEED_ARCHIVE_AI_REVIEW_ID=

# Reviewer slots. Оба слота должны быть сконфигурированы при включенной фиче.
# Сегодня оба могут указывать на codex; в будущем REVIEW_ROLE_SECONDARY станет
# claude или другим агентом. Модели должны различаться, иначе кросс-ревью
# теряет смысл.
REVIEW_ROLE_PRIMARY=
REVIEW_ROLE_SECONDARY=
REVIEW_PRIMARY_MODEL=
REVIEW_SECONDARY_MODEL=
REVIEW_PRIMARY_EXECUTOR_PATH=
REVIEW_SECONDARY_EXECUTOR_PATH=

# Опциональные runtime-настройки review-стадии.
REVIEW_MAX_CONTEXT_BYTES=
REVIEW_PARSE_REPAIR_RETRIES=
REVIEW_PROMPT_DIR=

# Telegram notifications
TELEGRAM_NOTIFICATIONS_ENABLED=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_URL=
TELEGRAM_TIMEOUT=

# ELK integration
LOGSTASH_ADDR=
LOGSTASH_BUFFER_SIZE=
LOGSTASH_DIAL_TIMEOUT=
